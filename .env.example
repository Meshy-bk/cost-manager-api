# Copy this file to .env and fill in your own values.

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/costmanager

# Port for each process
USERS_PORT=2001
COSTS_PORT=2002
LOGS_PORT=2003
ADMIN_PORT=2004

# Users service URL (the costs service calls it to verify a user exists)
USERS_SERVICE_URL=http://localhost:2001

NODE_ENV=development
